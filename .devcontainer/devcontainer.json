{
  "name": "Rinha das Lendas",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/RinhaDasLendas",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    }
  },
  "forwardPorts": [5000, 5173, 5432],
  "portsAttributes": {
    "5000": {
      "label": "Backend API"
    },
    "5173": {
      "label": "Frontend Vite"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "dev.containers.mountWaylandSocket": false
      }
    }
  },
  "containerEnv": {
    "DISPLAY": "",
    "WAYLAND_DISPLAY": "",
    "XDG_RUNTIME_DIR": ""
  },
  "remoteUser": "vscode"
}