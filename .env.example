# Domains / Traefik
FRONTEND_DOMAIN=rinha.igorkaique.dev
API_DOMAIN=api.rinha.igorkaique.dev
FRONTEND_PUBLIC_URL=https://rinha.igorkaique.dev
BACKEND_PUBLIC_URL=https://api.rinha.igorkaique.dev
TRAEFIK_NETWORK=RonaLab
TRAEFIK_CERTRESOLVER=letsencryptresolver

# PostgreSQL
POSTGRES_DB=rinha_das_lendas
POSTGRES_USER=rinha_user
POSTGRES_PASSWORD=change-me

# Backend
BACKEND_ALLOWED_HOSTS=api.rinha.igorkaique.dev
DRAFT_REALTIME_MAX_DURATION_MINUTES=120

# JWT
JWT_ISSUER=RinhaDasLendas
JWT_AUDIENCE=RinhaDasLendas.FrontEnd
JWT_KEY=change-me-generate-a-long-random-secret-with-at-least-64-chars
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14

# Bootstrap SuperAdmin
BOOTSTRAP_SUPER_ADMIN_ENABLED=false
BOOTSTRAP_SUPER_ADMIN_NAME="Super Admin"
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_PASSWORD=

# Discord OAuth / Bot shared
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://api.rinha.igorkaique.dev/api/v1/auth/discord/callback
DISCORD_SCOPES="identify email"
FRONTEND_AUTH_SUCCESS_URL=https://rinha.igorkaique.dev/configuracoes?discord=success
FRONTEND_AUTH_ERROR_URL=https://rinha.igorkaique.dev/configuracoes?discord=error
FRONTEND_AUTH_LOGIN_ERROR_URL=https://rinha.igorkaique.dev/login?discord=error
RINHA_API_INTERNAL_TOKEN=change-me-generate-a-long-random-secret

# Discord Bot
DISCORD_TOKEN=
DISCORD_GUILD_ID=
BOT_LOCALE=pt-BR
BOT_LOG_LEVEL=info

# Frontend build
VITE_API_URL=https://api.rinha.igorkaique.dev
VITE_ENABLE_FAKE_FALLBACK=false
